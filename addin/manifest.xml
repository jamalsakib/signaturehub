<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- Basic info -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>SignatureHub</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="SignatureHub"/>
  <Description DefaultValue="Automatically insert your branded corporate email signature."/>
  <IconUrl DefaultValue="https://your-signaturehub-domain.com/addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://your-signaturehub-domain.com/addin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://your-signaturehub-domain.com/support"/>

  <!-- Required -->
  <AppDomains>
    <AppDomain>your-signaturehub-domain.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://your-signaturehub-domain.com/addin/taskpane.html"/>
        <RequestedHeight>200</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="functionFile"/>

          <!-- Compose command: auto-insert signature button in ribbon -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="signatureGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="insertSignatureButton">
                  <Label resid="buttonLabel"/>
                  <Supertip>
                    <Title resid="buttonLabel"/>
                    <Description resid="buttonTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>insertSignature</FunctionName>
                  </Action>
                </Control>

                <!-- Taskpane button -->
                <Control xsi:type="Button" id="openTaskpaneButton">
                  <Label resid="taskpaneButtonLabel"/>
                  <Supertip>
                    <Title resid="taskpaneButtonLabel"/>
                    <Description resid="taskpaneTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>signatureTaskpane</TaskpaneId>
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Auto-open on new compose (requires Mailbox 1.10+) -->
          <ExtensionPoint xsi:type="AutoRunEvents">
            <bt:AutoRunEvents>
              <bt:LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageComposeHandler"/>
            </bt:AutoRunEvents>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://your-signaturehub-domain.com/addin/assets/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://your-signaturehub-domain.com/addin/assets/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://your-signaturehub-domain.com/addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="functionFile" DefaultValue="https://your-signaturehub-domain.com/addin/function.html"/>
        <bt:Url id="taskpaneUrl" DefaultValue="https://your-signaturehub-domain.com/addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Signature"/>
        <bt:String id="buttonLabel" DefaultValue="Insert Signature"/>
        <bt:String id="taskpaneButtonLabel" DefaultValue="Manage Signature"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="buttonTooltip" DefaultValue="Automatically insert your corporate email signature."/>
        <bt:String id="taskpaneTooltip" DefaultValue="View and manage your corporate email signature."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
