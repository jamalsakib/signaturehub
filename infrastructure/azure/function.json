{
  "bindings": [
    {
      "name": "timer",
      "type": "timerTrigger",
      "direction": "in",
      "schedule": "0 0 */6 * * *",
      "runOnStartup": false
    },
    {
      "name": "outputBlob",
      "type": "blob",
      "direction": "out",
      "path": "sync-logs/{DateTime}.json",
      "connection": "AzureWebJobsStorage"
    }
  ]
}
