# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/email_signature_platform

# Redis
REDIS_URL=redis://localhost:6379

# Azure AD / Microsoft 365
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URI=http://localhost:5000/api/auth/callback

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Azure Blob Storage (for logos/banners)
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_STORAGE_KEY=your-storage-key
AZURE_STORAGE_CONTAINER=signature-assets

# Graph API Scopes
GRAPH_SCOPES=https://graph.microsoft.com/.default

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Sync Schedule (cron format - default: every 6 hours)
USER_SYNC_SCHEDULE=0 */6 * * *

# Encryption key for token storage
ENCRYPTION_KEY=32-char-encryption-key-here!!!!

# API Key for Outlook add-in / external signature generation
API_KEY=your-secure-api-key-here
